# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Node / JS ─────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── SvelteKit build artifacts ─────────────────────────────────────────────────
/build/
/.svelte-kit/
/package/

# ── Vite ──────────────────────────────────────────────────────────────────────
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ── Environment / secrets — NEVER commit API keys! ────────────────────────────
.env
.env.*
!.env.example

# ── Rust / Cargo ──────────────────────────────────────────────────────────────
src-tauri/target/
src-tauri/gen/schemas/

# ── Tauri build output ────────────────────────────────────────────────────────
src-tauri/target/
# Bundles (NSIS, MSI, AppImage, dmg…) — usually too large for git
src-tauri/target/release/bundle/

# ── IDE / editors ─────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.user
*.swp
*.swo

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.tmp