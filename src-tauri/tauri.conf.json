{
	"$schema": "https://schema.tauri.app/config/2.0.0",
	"productName": "Infinity Loop",
	"version": "1.0.0",
	"identifier": "com.ar3love.infinity-loop",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": "npm run dev",
		"beforeBuildCommand": "npm run build"
	},
	"bundle": {
		"active": true,
		"targets": [
			"nsis"
		],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"publisher": "arelove",
		"category": "Utility",
		"shortDescription": "AI knowledge explorer",
		"longDescription": "Explore any topic as an interactive knowledge graph, powered by Gemini and Tavily. Works on Windows 10 and 11.",
		"homepage": "https://github.com/arelove/infinity-loop",
		"windows": {
			"certificateThumbprint": null,
			"digestAlgorithm": "sha256",
			"timestampUrl": "http://timestamp.digicert.com",
			"allowDowngrades": false,
			"webviewInstallMode": {
				"type": "embedBootstrapper"
			},
			"nsis": {
				"installerIcon": "icons/icon.ico",
				"installMode": "currentUser",
				"languages": [
					"English",
					"Russian"
				],
				"displayLanguageSelector": true
			}
		}
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "Infinity Loop",
				"width": 1280,
				"height": 800,
				"minWidth": 900,
				"minHeight": 600,
				"resizable": true,
				"fullscreen": false,
				"decorations": true,
				"center": true,
				"transparent": false,
				"alwaysOnTop": false,
				"skipTaskbar": false,
				"visible": true,
				"focus": true,
				"maximized": false,
				"url": "/"
			}
		],
		"security": {
			"csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.tavily.com https://generativelanguage.googleapis.com https://www.google.com https://fonts.googleapis.com; img-src 'self' data: https: blob:;",
			"assetProtocol": {
				"enable": true
			}
		},
		"withGlobalTauri": false
	}
}